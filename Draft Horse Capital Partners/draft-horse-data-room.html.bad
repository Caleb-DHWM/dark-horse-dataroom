<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Draft Horse Capital Partners — Institutional Due Diligence Data Room</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#080c18;--navy-mid:#0e1624;--navy-light:#16213a;--navy-card:#1a2840;
  --gold:#c9a84c;--gold-light:#e8c87a;--gold-dim:#7a5f28;--gold-xdim:#3a2e12;
  --silver:#8fa3b8;--silver-light:#c8d8e8;--white:#f0f4f8;
  --text:#cdd8e6;--text-muted:#6a88a0;
  --border:rgba(201,168,76,0.2);--border-dim:rgba(255,255,255,0.07);
  --green:#22c55e;--red:#f87171;--amber:#fbbf24;--blue:#60a5fa;
  --sidebar-w:276px;--header-h:64px;
}
html{scroll-behavior:smooth}
body{font-family:'Georgia','Times New Roman',serif;background:var(--navy);color:var(--text);line-height:1.75;font-size:15px;overflow-x:hidden}
h1,h2,h3,h4,h5{font-family:'Georgia',serif;color:var(--white);line-height:1.25;font-weight:normal;letter-spacing:.02em}
a{color:var(--gold);text-decoration:none}a:hover{color:var(--gold-light)}
strong{color:var(--white);font-weight:bold}em{color:var(--gold-light);font-style:italic}
.disclaimer-bar{position:fixed;bottom:0;left:0;right:0;background:rgba(8,12,24,.97);border-top:1px solid rgba(201,168,76,.15);padding:7px 20px;font-family:'Arial',sans-serif;font-size:9.5px;color:var(--text-muted);text-align:center;z-index:1000;line-height:1.4}
.disclaimer-bar strong{color:var(--gold);font-size:9.5px}
.header{position:fixed;top:0;left:0;right:0;height:var(--header-h);background:rgba(8,12,24,.98);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 28px 0 calc(var(--sidebar-w) + 28px);z-index:900;backdrop-filter:blur(10px)}
.header-logo{display:flex;align-items:center;gap:14px}
.header-emblem{width:38px;height:38px;border:1.5px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--gold);font-family:'Arial',sans-serif;font-weight:800;letter-spacing:.05em;background:rgba(201,168,76,.06)}
.header-name{font-family:'Arial',sans-serif;font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--silver-light)}
.header-name span{color:var(--gold)}
.header-badge{font-family:'Arial',sans-serif;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold-dim);border:1px solid var(--gold-dim);padding:4px 10px;border-radius:2px}
.sidebar{position:fixed;top:var(--header-h);left:0;width:var(--sidebar-w);height:calc(100vh - var(--header-h) - 32px);background:var(--navy-mid);border-right:1px solid var(--border-dim);overflow-y:auto;padding:16px 0;z-index:800}
.sidebar::-webkit-scrollbar{width:3px}.sidebar::-webkit-scrollbar-thumb{background:var(--gold-dim);border-radius:2px}
.sidebar-label{font-family:'Arial',sans-serif;font-size:8px;letter-spacing:.24em;text-transform:uppercase;color:var(--gold-dim);padding:12px 16px 4px;margin-top:4px}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 16px;cursor:pointer;transition:all .15s;border-left:3px solid transparent;font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.03em;color:var(--silver)}
.nav-item:hover{background:rgba(201,168,76,.06);color:var(--gold-light);border-left-color:var(--gold-dim)}
.nav-item.active{background:rgba(201,168,76,.1);color:var(--gold);border-left-color:var(--gold)}
.nav-num{font-size:9px;color:var(--gold-dim);min-width:17px;font-family:'Arial',sans-serif;font-weight:700}
.nav-item.active .nav-num{color:var(--gold)}
.main{margin-left:var(--sidebar-w);margin-top:var(--header-h);padding:48px 60px 80px;min-height:calc(100vh - var(--header-h))}
.section{display:none;animation:fadeIn .28s ease;max-width:1040px}
.section.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.sec-hdr{border-bottom:1px solid var(--border);padding-bottom:20px;margin-bottom:36px}
.sec-num{font-family:'Arial',sans-serif;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:7px}
.sec-title{font-size:30px;color:var(--white);letter-spacing:.03em}
.sec-sub{font-family:'Arial',sans-serif;font-size:13px;color:var(--silver);margin-top:6px;letter-spacing:.04em}
.gold-rule{width:56px;height:2px;background:var(--gold);margin:16px 0 0}
.card{background:var(--navy-card);border:1px solid var(--border-dim);border-radius:5px;padding:26px 30px;margin-bottom:22px}
.card-gold{border-left:4px solid var(--gold);border-color:var(--border)}
.card-blue{border-left:4px solid var(--blue);border-color:rgba(96,165,250,.2)}
.card-green{border-left:4px solid var(--green);border-color:rgba(34,197,94,.2)}
.card-red{border-left:4px solid var(--red);border-color:rgba(248,113,113,.2)}
.card h3{font-size:17px;color:var(--gold-light);margin-bottom:14px;letter-spacing:.04em}
.card h4{font-family:'Arial',sans-serif;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--silver-light);margin-bottom:10px}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:28px}
.stat-box{background:var(--navy-light);border:1px solid var(--border);padding:20px 18px;border-radius:5px;text-align:center}
.stat-val{font-size:28px;color:var(--gold);font-family:'Georgia',serif;line-height:1.1;margin-bottom:6px}
.stat-lbl{font-family:'Arial',sans-serif;font-size:9.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--text-muted)}
table{width:100%;border-collapse:collapse;font-family:'Arial',sans-serif;font-size:12.5px;margin-bottom:22px}
thead tr{background:var(--navy-light);border-bottom:2px solid var(--gold-dim)}
thead th{padding:10px 13px;text-align:left;color:var(--gold);font-size:9px;letter-spacing:.14em;text-transform:uppercase;font-weight:700}
tbody tr{border-bottom:1px solid var(--border-dim);transition:background .1s}
tbody tr:hover{background:rgba(201,168,76,.04)}
tbody tr:last-child{border-bottom:none}
tbody td{padding:10px 13px;color:var(--text);vertical-align:middle}
tbody td:first-child{color:var(--silver-light)}
.td-gold{color:var(--gold)!important;font-weight:700}
.td-green{color:var(--green)!important;font-weight:700}
.td-red{color:var(--red)!important}
.td-hl{background:rgba(201,168,76,.06)}
.check{color:var(--green)}.cross{color:var(--red)}.partial{color:var(--amber)}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.four-col{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:14px}
@media(max-width:800px){.two-col,.three-col,.four-col{grid-template-columns:1fr}}
.content p{margin-bottom:14px}
.content ul{margin:10px 0 14px 24px}
.content ul li{margin-bottom:6px;color:var(--text);font-size:14px;line-height:1.65}
.content ol{margin:10px 0 14px 24px}
.content ol li{margin-bottom:7px;color:var(--text);font-size:14px;line-height:1.65}
.callout{background:rgba(201,168,76,.07);border-left:4px solid var(--gold);padding:15px 20px;border-radius:0 4px 4px 0;margin:20px 0;font-size:14px;color:var(--silver-light);line-height:1.7}
.callout strong{color:var(--gold)}
.callout-warn{background:rgba(248,113,113,.07);border-left:4px solid var(--red);padding:15px 20px;border-radius:0 4px 4px 0;margin:20px 0;font-size:13.5px;color:var(--silver-light);line-height:1.7}
.callout-warn strong{color:var(--red)}
.info-box{background:rgba(8,12,24,.6);border:1px solid var(--border-dim);padding:13px 18px;border-radius:4px;margin:16px 0;font-family:'Arial',sans-serif;font-size:11.5px;color:var(--text-muted);line-height:1.7}
.info-box strong{color:var(--silver-light)}
.tag{display:inline-block;font-family:'Arial',sans-serif;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;padding:4px 10px;border-radius:2px;margin:3px 3px 3px 0}
.tag-gold{background:rgba(201,168,76,.14);color:var(--gold);border:1px solid var(--gold-dim)}
.tag-blue{background:rgba(96,165,250,.1);color:#7eb8d8;border:1px solid rgba(96,165,250,.2)}
.tag-green{background:rgba(34,197,94,.1);color:var(--green);border:1px solid rgba(34,197,94,.25)}
.tag-red{background:rgba(248,113,113,.1);color:var(--red);border:1px solid rgba(248,113,113,.25)}
.lv-list{list-style:none;padding:0}
.lv-list li{display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border-dim);font-family:'Arial',sans-serif;font-size:12.5px}
.lv-list li:last-child{border-bottom:none}
.lv-lbl{color:var(--text-muted)}.lv-val{color:var(--white);text-align:right;max-width:58%}
.yield-row{display:flex;align-items:center;gap:13px;margin-bottom:9px}
.yield-lbl{font-family:'Arial',sans-serif;font-size:12px;color:var(--silver);min-width:175px}
.yield-wrap{flex:1;height:29px;background:var(--navy-light);border-radius:3px;overflow:hidden;border:1px solid var(--border-dim)}
.yield-bar{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--gold-dim),var(--gold) 80%,var(--gold-light));display:flex;align-items:center;padding-left:10px}
.yield-pct{font-family:'Arial',sans-serif;font-size:12px;font-weight:700;color:var(--navy);white-space:nowrap}
.steps{display:flex;flex-direction:column;gap:0;position:relative;padding-left:40px}
.steps::before{content:'';position:absolute;left:14px;top:20px;bottom:20px;width:2px;background:linear-gradient(to bottom,var(--gold),var(--gold-dim),transparent)}
.step{position:relative;padding:13px 0}
.step::before{content:attr(data-n);position:absolute;left:-40px;top:13px;width:28px;height:28px;background:var(--navy-card);border:2px solid var(--gold);border-radius:50%;font-family:'Arial',sans-serif;font-size:10px;font-weight:700;color:var(--gold);text-align:center;line-height:24px}
.step h4{font-family:'Arial',sans-serif;font-size:11.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold-light);margin-bottom:5px}
.step p{font-size:13.5px;color:var(--text);line-height:1.65}
.risk-item{border-left:3px solid var(--gold-dim);padding:14px 20px;margin-bottom:14px;background:rgba(8,12,24,.5);border-radius:0 4px 4px 0}
.risk-item h4{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:8px}
.risk-item p{font-size:13px;color:var(--text);line-height:1.7}
.layer-item{background:var(--navy-card);border:1px solid var(--border-dim);border-left:5px solid var(--gold-dim);border-radius:0 5px 5px 0;padding:22px 28px 22px 22px;margin-bottom:4px;transition:all .2s}
.layer-item:hover{background:rgba(30,45,70,.9);border-left-color:var(--gold);transform:translateX(3px)}
.layer-item.l1{border-left-color:#22c55e}.layer-item.l2{border-left-color:#3b82f6}
.layer-item.l3{border-left-color:#8b5cf6}.layer-item.l4{border-left-color:var(--gold)}
.layer-item.l5{border-left-color:#ef4444}
.layer-badge{font-family:'Arial',sans-serif;font-size:8.5px;letter-spacing:.18em;text-transform:uppercase;margin-bottom:6px;font-weight:700}
.l1 .layer-badge{color:#22c55e}.l2 .layer-badge{color:#3b82f6}.l3 .layer-badge{color:#8b5cf6}
.l4 .layer-badge{color:var(--gold)}.l5 .layer-badge{color:#ef4444}
.layer-title{font-size:17px;color:var(--white);margin-bottom:9px}
.layer-body{font-size:13.5px;color:var(--text);line-height:1.7}
.cover-wrap{min-height:calc(100vh - var(--header-h) - 100px);display:flex;flex-direction:column;justify-content:center}
.cover-eyebrow{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:16px}
.cover-title{font-size:52px;color:var(--white);letter-spacing:.04em;line-height:1.08;margin-bottom:12px}
.cover-tag{font-size:19px;color:var(--silver);font-style:italic;margin-bottom:34px;letter-spacing:.02em}
.cover-meta{display:flex;gap:40px;flex-wrap:wrap;margin-bottom:38px}
.cm-item{display:flex;flex-direction:column;gap:5px}
.cm-lbl{font-family:'Arial',sans-serif;font-size:9.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold-dim)}
.cm-val{font-family:'Arial',sans-serif;font-size:14px;color:var(--silver-light)}
.cover-div{width:100%;height:1px;background:linear-gradient(to right,var(--gold),transparent);margin:30px 0}
.cio-letter{background:linear-gradient(135deg,rgba(26,40,64,.9),rgba(8,12,24,.4));border:1px solid var(--border);border-top:4px solid var(--gold);padding:42px 48px;border-radius:5px;margin-bottom:26px;position:relative}
.cio-letter::before{content:'\201C';position:absolute;top:18px;left:34px;font-size:76px;color:rgba(201,168,76,.1);font-family:'Georgia',serif;line-height:1}
.cio-para{font-size:15px;color:var(--text);line-height:1.85;margin-bottom:20px}
.cio-sig{margin-top:32px;padding-top:22px;border-top:1px solid rgba(201,168,76,.2)}
.cio-name{font-size:18px;color:var(--white);letter-spacing:.04em;margin-bottom:4px}
.cio-title{font-family:'Arial',sans-serif;font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold)}
.spec-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin:18px 0}
.spec-box{background:var(--navy-light);border:1px solid var(--border-dim);border-radius:4px;padding:16px 18px}
.spec-lbl{font-family:'Arial',sans-serif;font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:var(--text-muted);margin-bottom:6px}
.spec-val{font-size:17px;color:var(--gold);font-family:'Georgia',serif}
.spec-sub{font-family:'Arial',sans-serif;font-size:11px;color:var(--silver);margin-top:3px}
.proj-row{display:flex;justify-content:space-between;align-items:center;padding:11px 0;border-bottom:1px solid var(--border-dim)}
.proj-row:last-child{border-bottom:none}
.proj-lbl{font-family:'Arial',sans-serif;font-size:13px;color:var(--silver)}
.proj-val{font-size:18px;color:var(--gold);font-family:'Georgia',serif;font-weight:bold}
.proj-val.big{font-size:26px;color:var(--gold-light)}
.proj-total{background:rgba(201,168,76,.08);border:1px solid var(--border);border-radius:4px;padding:18px 22px;margin-top:12px}
.glossary-term{padding:14px 0;border-bottom:1px solid var(--border-dim)}
.glossary-term:last-child{border-bottom:none}
.gt-word{font-size:15px;color:var(--gold-light);margin-bottom:5px;letter-spacing:.02em}
.gt-def{font-family:'Arial',sans-serif;font-size:13px;color:var(--text);line-height:1.7}
.rights-item{display:flex;align-items:flex-start;gap:14px;padding:14px 0;border-bottom:1px solid var(--border-dim)}
.rights-item:last-child{border-bottom:none}
.rights-check{color:var(--green);font-size:16px;margin-top:2px;min-width:20px}
.rights-content h4{font-family:'Arial',sans-serif;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--gold-light);margin-bottom:5px}
.rights-content p{font-family:'Arial',sans-serif;font-size:13px;color:var(--text);line-height:1.65}
.pipeline-bar{background:var(--navy-light);border-radius:4px;overflow:hidden;height:44px;margin:14px 0;border:1px solid var(--border-dim)}
.pipeline-fill{height:100%;background:linear-gradient(90deg,var(--gold-dim),var(--gold) 60%,var(--gold-light));display:flex;align-items:center;padding:0 18px;font-family:'Arial',sans-serif;font-size:13px;font-weight:700;color:var(--navy);width:100%;animation:growBar 1.2s ease-out}
@keyframes growBar{from{width:0}}
.org-chart{display:flex;flex-direction:column;align-items:center;gap:0;padding:20px 0}
.org-node{background:var(--navy-card);border:1px solid var(--border);padding:13px 28px;border-radius:4px;text-align:center;min-width:250px}
.org-node.fund{border-color:var(--gold);border-width:2px;background:linear-gradient(135deg,var(--navy-card),rgba(201,168,76,.08))}
.org-node-t{font-family:'Arial',sans-serif;font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:3px}
.org-node-n{font-size:14px;color:var(--white);letter-spacing:.02em}
.org-node-s{font-family:'Arial',sans-serif;font-size:10.5px;color:var(--text-muted);margin-top:3px}
.org-conn{width:2px;height:24px;background:var(--gold-dim);position:relative}
.org-conn::after{content:'▼';position:absolute;bottom:-5px;left:50%;transform:translateX(-50%);color:var(--gold-dim);font-size:7px}
.provider-card{background:var(--navy-card);border:1px solid var(--border-dim);border-top:3px solid var(--gold);padding:20px 22px;border-radius:4px}
.prov-role{font-family:'Arial',sans-serif;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:5px}
.prov-name{font-size:17px;color:var(--white);margin-bottom:10px;letter-spacing:.02em}
.prov-desc{font-family:'Arial',sans-serif;font-size:12px;color:var(--text-muted);line-height:1.65}
.contact-card{background:var(--navy-card);border:1px solid var(--border);border-top:4px solid var(--gold);padding:36px 40px;border-radius:4px;max-width:560px}
.contact-name{font-size:23px;color:var(--white);margin-bottom:4px;letter-spacing:.03em}
.contact-title{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:24px;line-height:1.7}
.contact-row{display:flex;align-items:flex-start;gap:13px;margin-bottom:14px;font-family:'Arial',sans-serif;font-size:13px;color:var(--text)}
.contact-icon{color:var(--gold);font-size:13px;min-width:18px;text-align:center;margin-top:2px}
.sec-notice{font-family:'Arial',sans-serif;font-size:9.5px;color:var(--text-muted);text-align:right;margin-top:48px;padding-top:11px;border-top:1px solid var(--border-dim);letter-spacing:.05em}
@media print{.sidebar,.header,.disclaimer-bar{display:none!important}.main{margin:0;padding:20px 40px}.section{display:block!important;page-break-before:always}.section:first-child{page-break-before:avoid}body{background:#fff;color:#111}.card,.stat-box{border-color:#ccc;background:#fafafa}h1,h2,h3{color:#111}a{color:#333}}
@media(max-width:960px){:root{--sidebar-w:220px}.main{padding:36px 30px 80px}.cover-title{font-size:36px}}
@media(max-width:680px){.sidebar{display:none}:root{--sidebar-w:0px}.header{padding-left:20px}.main{padding:24px 16px 80px}}
</style>
</head>
<body>

<header class="header">
  <div class="header-logo">
    <div class="header-emblem">DH</div>
    <div><div class="header-name"><span>Draft Horse</span> Capital Partners</div></div>
  </div>
  <div class="header-badge">Confidential — Institutional Due Diligence Data Room — March 2026</div>
</header>

<nav class="sidebar">
  <div class="sidebar-label">Data Room</div>
  <div class="nav-item active" onclick="showSection('s01',this)"><span class="nav-num">01</span> Cover &amp; Confidentiality</div>
  <div class="nav-item" onclick="showSection('s02',this)"><span class="nav-num">02</span> Executive Summary</div>
  <div class="nav-item" onclick="showSection('s03',this)"><span class="nav-num">03</span> Investment Thesis</div>
  <div class="nav-item" onclick="showSection('s04',this)"><span class="nav-num">04</span> Market Opportunity</div>
  <div class="nav-item" onclick="showSection('s05',this)"><span class="nav-num">05</span> Fund Strategy</div>
  <div class="nav-item" onclick="showSection('s06',this)"><span class="nav-num">06</span> PE Sponsor Relationship</div>
  <div class="nav-item" onclick="showSection('s07',this)"><span class="nav-num">07</span> Deal Structure Mechanics</div>
  <div class="nav-item" onclick="showSection('s08',this)"><span class="nav-num">08</span> Five-Layer Collateral</div>
  <div class="nav-item" onclick="showSection('s09',this)"><span class="nav-num">09</span> Aviation Deep Dive</div>
  <div class="nav-item" onclick="showSection('s10',this)"><span class="nav-num">10</span> Fund Terms</div>
  <div class="nav-item" onclick="showSection('s11',this)"><span class="nav-num">11</span> Fee Structure</div>
  <div class="nav-item" onclick="showSection('s12',this)"><span class="nav-num">12</span> Financial Projections</div>
  <div class="nav-item" onclick="showSection('s13',this)"><span class="nav-num">13</span> Portfolio Management</div>
  <div class="nav-item" onclick="showSection('s14',this)"><span class="nav-num">14</span> Risk Factors</div>
  <div class="nav-item" onclick="showSection('s15',this)"><span class="nav-num">15</span> Track Record</div>
  <div class="nav-item" onclick="showSection('s16',this)"><span class="nav-num">16</span> Management</div>
  <div class="nav-item" onclick="showSection('s17',this)"><span class="nav-num">17</span> Organizational Structure</div>
