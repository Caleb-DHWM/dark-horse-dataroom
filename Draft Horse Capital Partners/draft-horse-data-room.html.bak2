<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Draft Horse Capital Partners — Confidential Investor Data Room</title>
<style>
  /* ============================================================
     RESET & BASE
  ============================================================ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:        #080c18;
    --navy-mid:    #0e1624;
    --navy-light:  #16213a;
    --navy-card:   #1a2840;
    --gold:        #c9a84c;
    --gold-light:  #e8c87a;
    --gold-dim:    #7a5f28;
    --gold-xdim:   #4a3a18;
    --silver:      #8fa3b8;
    --silver-light:#c8d8e8;
    --white:       #f0f4f8;
    --text:        #cdd8e6;
    --text-muted:  #6a88a0;
    --border:      rgba(201,168,76,0.2);
    --border-dim:  rgba(255,255,255,0.07);
    --green:       #22c55e;
    --red:         #f87171;
    --amber:       #fbbf24;
    --sidebar-w:   268px;
    --header-h:    64px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Georgia', 'Times New Roman', serif;
    background: var(--navy);
    color: var(--text);
    line-height: 1.75;
    font-size: 15px;
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5 {
    font-family: 'Georgia', serif;
    color: var(--white);
    line-height: 1.25;
    font-weight: normal;
    letter-spacing: 0.02em;
  }

  a { color: var(--gold); text-decoration: none; }
  a:hover { color: var(--gold-light); }
  strong { color: var(--white); font-weight: bold; }
  em { color: var(--gold-light); font-style: italic; }

  /* ============================================================
     DISCLAIMER BAR
  ============================================================ */
  .disclaimer-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: rgba(8,12,24,0.97);
    border-top: 1px solid rgba(201,168,76,0.15);
    padding: 7px 20px;
    font-family: 'Arial', sans-serif;
    font-size: 9.5px;
    color: var(--text-muted);
    text-align: center;
    z-index: 1000;
    line-height: 1.4;
  }
  .disclaimer-bar strong { color: var(--gold); font-size: 9.5px; }

  /* ============================================================
     HEADER
  ============================================================ */
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--header-h);
    background: rgba(8,12,24,0.98);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px 0 calc(var(--sidebar-w) + 28px);
    z-index: 900;
    backdrop-filter: blur(10px);
  }
  .header-logo { display: flex; align-items: center; gap: 14px; }
  .header-emblem {
    width: 38px; height: 38px;
    border: 1.5px solid var(--gold);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; color: var(--gold);
    font-family: 'Arial', sans-serif; font-weight: 700;
    letter-spacing: 0.05em;
    background: rgba(201,168,76,0.06);
  }
  .header-name {
    font-family: 'Arial', sans-serif;
    font-size: 12px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--silver-light);
  }
  .header-name span { color: var(--gold); }
  .header-right { display: flex; align-items: center; gap: 16px; }
  .header-badge {
    font-family: 'Arial', sans-serif;
    font-size: 9px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--gold-dim);
    border: 1px solid var(--gold-dim);
    padding: 4px 10px; border-radius: 2px;
  }

  /* ============================================================
     SIDEBAR
  ============================================================ */
  .sidebar {
    position: fixed;
    top: var(--header-h); left: 0;
    width: var(--sidebar-w);
    height: calc(100vh - var(--header-h) - 32px);
    background: var(--navy-mid);
    border-right: 1px solid var(--border-dim);
    overflow-y: auto; padding: 20px 0; z-index: 800;
  }
  .sidebar::-webkit-scrollbar { width: 3px; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--gold-dim); border-radius: 2px; }

  .sidebar-section-label {
    font-family: 'Arial', sans-serif;
    font-size: 8.5px; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--gold-dim);
    padding: 14px 18px 5px; margin-top: 6px;
  }
  .sidebar-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 18px; cursor: pointer;
    transition: all 0.15s ease;
    border-left: 3px solid transparent;
    font-family: 'Arial', sans-serif;
    font-size: 11.5px; letter-spacing: 0.03em; color: var(--silver);
  }
  .sidebar-item:hover {
    background: rgba(201,168,76,0.06);
    color: var(--gold-light); border-left-color: var(--gold-dim);
  }
  .sidebar-item.active {
    background: rgba(201,168,76,0.1);
    color: var(--gold); border-left-color: var(--gold);
  }
  .sidebar-num {
    font-size: 9.5px; color: var(--gold-dim);
    min-width: 18px; font-family: 'Arial', sans-serif; font-weight: 700;
  }
  .sidebar-item.active .sidebar-num { color: var(--gold); }

  /* ============================================================
     MAIN CONTENT
  ============================================================ */
  .main {
    margin-left: var(--sidebar-w);
    margin-top: var(--header-h);
    padding: 52px 64px 88px;
    min-height: calc(100vh - var(--header-h));
  }

  .section {
    display: none;
    animation: fadeIn 0.28s ease;
    max-width: 1020px;
  }
  .section.active { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ============================================================
     SECTION HEADER
  ============================================================ */
  .section-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 22px; margin-bottom: 38px;
  }
  .section-number {
    font-family: 'Arial', sans-serif; font-size: 10px;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--gold-dim); margin-bottom: 8px;
  }
  .section-title { font-size: 30px; color: var(--white); letter-spacing: 0.03em; }
  .section-subtitle {
    font-family: 'Arial', sans-serif; font-size: 13px;
    color: var(--silver); margin-top: 6px; letter-spacing: 0.04em;
  }
  .gold-rule { width: 60px; height: 2px; background: var(--gold); margin: 18px 0 0; }

  /* ============================================================
     CARDS & BLOCKS
  ============================================================ */
  .card {
    background: var(--navy-card);
    border: 1px solid var(--border-dim);
    border-radius: 5px; padding: 28px 32px; margin-bottom: 24px;
  }
  .card-gold { border-color: var(--border); border-left: 4px solid var(--gold); }
  .card h3 {
    font-size: 17px; color: var(--gold-light);
    margin-bottom: 15px; letter-spacing: 0.04em;
  }
  .card h4 {
    font-family: 'Arial', sans-serif; font-size: 10.5px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--silver-light); margin-bottom: 10px;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 16px; margin-bottom: 30px;
  }
  .stat-box {
    background: var(--navy-light);
    border: 1px solid var(--border);
    padding: 22px 20px; border-radius: 5px; text-align: center;
  }
  .stat-value {
    font-size: 28px; color: var(--gold);
    font-family: 'Georgia', serif; line-height: 1.1; margin-bottom: 7px;
  }
  .stat-label {
    font-family: 'Arial', sans-serif; font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted);
  }

  /* ============================================================
     TABLES
  ============================================================ */
  table { width: 100%; border-collapse: collapse; font-family: 'Arial', sans-serif; font-size: 12.5px; margin-bottom: 24px; }
  thead tr { background: var(--navy-light); border-bottom: 2px solid var(--gold-dim); }
  thead th { padding: 11px 14px; text-align: left; color: var(--gold); font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; }
  tbody tr { border-bottom: 1px solid var(--border-dim); transition: background 0.1s; }
  tbody tr:hover { background: rgba(201,168,76,0.04); }
  tbody tr:last-child { border-bottom: none; }
  tbody td { padding: 11px 14px; color: var(--text); vertical-align: middle; }
  tbody td:first-child { color: var(--silver-light); }
  .td-gold { color: var(--gold) !important; font-weight: 700; }
  .td-green { color: var(--green) !important; font-weight: 700; }
  .td-red { color: var(--red) !important; }
  .td-highlight { background: rgba(201,168,76,0.07); }
  .check { color: var(--green); }
  .cross { color: var(--red); }
  .partial { color: var(--amber); }

  /* ============================================================
     YIELD BARS
  ============================================================ */
  .yield-tier { display: flex; align-items: center; gap: 14px; margin-bottom: 10px; }
  .yield-label { font-family: 'Arial', sans-serif; font-size: 12px; color: var(--silver); min-width: 170px; }
  .yield-bar-wrap {
    flex: 1; height: 30px; background: var(--navy-light);
    border-radius: 3px; overflow: hidden;
    border: 1px solid var(--border-dim);
  }
  .yield-bar {
    height: 100%; border-radius: 3px;
    background: linear-gradient(90deg, var(--gold-dim), var(--gold) 80%, var(--gold-light));
    display: flex; align-items: center; padding-left: 10px;
    transition: width 0.9s ease;
  }
  .yield-pct {
    font-family: 'Arial', sans-serif; font-size: 12.5px;
    font-weight: 700; color: var(--navy); white-space: nowrap;
  }

  /* ============================================================
     TIMELINE / PROCESS STEPS
  ============================================================ */
  .process-steps {
    display: flex; flex-direction: column; gap: 0;
    position: relative; padding-left: 42px;
  }
  .process-steps::before {
    content: '';
    position: absolute; left: 15px; top: 22px; bottom: 22px;
    width: 2px;
    background: linear-gradient(to bottom, var(--gold), var(--gold-dim), transparent);
  }
  .process-step { position: relative; padding: 14px 0; }
  .process-step::before {
    content: attr(data-n);
    position: absolute; left: -42px; top: 14px;
    width: 30px; height: 30px;
    background: var(--navy-card); border: 2px solid var(--gold);
    border-radius: 50%;
    font-family: 'Arial', sans-serif; font-size: 11px;
    font-weight: 700; color: var(--gold); text-align: center; line-height: 26px;
  }
  .process-step h4 {
    font-family: 'Arial', sans-serif; font-size: 12px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--gold-light); margin-bottom: 6px;
  }
  .process-step p { font-size: 13.5px; color: var(--text); line-height: 1.65; }

  /* ============================================================
     RISK FACTORS
  ============================================================ */
  .risk-item {
    border-left: 3px solid var(--gold-dim);
    padding: 16px 22px; margin-bottom: 16px;
    background: rgba(8,12,24,0.55); border-radius: 0 4px 4px 0;
  }
  .risk-item h4 {
    font-family: 'Arial', sans-serif; font-size: 11.5px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 9px;
  }
  .risk-item p { font-size: 13px; color: var(--text); line-height: 1.7; }

  /* ============================================================
     CALLOUTS
  ============================================================ */
  .callout {
    background: rgba(201,168,76,0.07);
    border-left: 4px solid var(--gold);
    padding: 16px 22px; border-radius: 0 4px 4px 0;
    margin: 22px 0; font-size: 14px; color: var(--silver-light); line-height: 1.7;
  }
  .callout strong { color: var(--gold); }
  .callout-critical {
    background: rgba(201,168,76,0.1);
    border: 2px solid var(--gold);
    padding: 22px 26px; border-radius: 5px;
    margin: 22px 0; font-size: 14.5px; color: var(--silver-light); line-height: 1.75;
  }
  .callout-critical strong { color: var(--gold-light); }
  .info-box {
    background: rgba(8,12,24,0.6);
    border: 1px solid var(--border-dim);
    padding: 14px 20px; border-radius: 4px; margin: 18px 0;
    font-family: 'Arial', sans-serif; font-size: 11.5px;
    color: var(--text-muted); line-height: 1.7;
  }
  .info-box strong { color: var(--silver-light); }

  /* ============================================================
     TAGS
  ============================================================ */
  .tag {
    display: inline-block;
    font-family: 'Arial', sans-serif; font-size: 9.5px;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 4px 10px; border-radius: 2px; margin: 3px 3px 3px 0;
  }
  .tag-gold { background: rgba(201,168,76,0.14); color: var(--gold); border: 1px solid var(--gold-dim); }
  .tag-blue { background: rgba(100,160,220,0.1); color: #7eb8d8; border: 1px solid rgba(100,160,220,0.2); }
  .tag-green { background: rgba(34,197,94,0.1); color: var(--green); border: 1px solid rgba(34,197,94,0.25); }
  .tag-red { background: rgba(248,113,113,0.1); color: var(--red); border: 1px solid rgba(248,113,113,0.25); }

  /* ============================================================
     LAYOUT HELPERS
  ============================================================ */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 18px; }
  @media (max-width: 800px) {
    .two-col, .three-col { grid-template-columns: 1fr; }
  }

  .content p { margin-bottom: 15px; }
  .content ul { margin: 12px 0 15px 26px; }
  .content ul li { margin-bottom: 7px; color: var(--text); font-size: 14px; line-height: 1.65; }
  .content ol { margin: 12px 0 15px 26px; }
  .content ol li { margin-bottom: 8px; color: var(--text); font-size: 14px; line-height: 1.65; }

  .label-val-list { list-style: none; padding: 0; }
  .label-val-list li {
    display: flex; justify-content: space-between;
    padding: 10px 0; border-bottom: 1px solid var(--border-dim);
    font-family: 'Arial', sans-serif; font-size: 12.5px;
  }
  .label-val-list li:last-child { border-bottom: none; }
  .label-val-list .lv-label { color: var(--text-muted); }
  .label-val-list .lv-val { color: var(--white); text-align: right; max-width: 58%; }

  /* ============================================================
     COVER PAGE
  ============================================================ */
  .cover-wrap {
    min-height: calc(100vh - var(--header-h) - 100px);
    display: flex; flex-direction: column; justify-content: center;
    padding: 0 10px;
  }
  .cover-eyebrow {
    font-family: 'Arial', sans-serif; font-size: 11px;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 18px;
  }
  .cover-title {
    font-size: 54px; color: var(--white);
    letter-spacing: 0.04em; line-height: 1.08; margin-bottom: 14px;
  }
  .cover-tagline {
    font-size: 20px; color: var(--silver);
    font-style: italic; margin-bottom: 36px; letter-spacing: 0.02em;
  }
  .cover-meta-row {
    display: flex; gap: 44px; flex-wrap: wrap; margin-bottom: 42px;
  }
  .cover-meta-item { display: flex; flex-direction: column; gap: 5px; }
  .cover-meta-label {
    font-family: 'Arial', sans-serif; font-size: 9.5px;
    letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold-dim);
  }
  .cover-meta-val { font-family: 'Arial', sans-serif; font-size: 14px; color: var(--silver-light); }
  .cover-divider {
    width: 100%; height: 1px;
    background: linear-gradient(to right, var(--gold), transparent);
    margin: 34px 0;
  }
  .cover-confidential {
    background: rgba(201,168,76,0.05);
    border: 1px solid var(--border);
    border-left: 4px solid var(--gold);
    padding: 20px 26px; max-width: 720px; border-radius: 2px;
  }
  .cover-confidential-title {
    font-family: 'Arial', sans-serif; font-size: 9.5px;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 9px;
  }
  .cover-confidential p {
    font-family: 'Arial', sans-serif; font-size: 11.5px;
    color: var(--text-muted); line-height: 1.7;
  }

  /* ============================================================
     CIO LETTER
  ============================================================ */
  .cio-letter {
    background: linear-gradient(135deg, rgba(26,40,64,0.9) 0%, rgba(8,12,24,0.4) 100%);
    border: 1px solid var(--border);
    border-top: 4px solid var(--gold);
    padding: 44px 50px;
    border-radius: 5px;
    margin-bottom: 28px;
    position: relative;
  }
  .cio-letter::before {
    content: '\201C';
    position: absolute;
    top: 20px; left: 36px;
    font-size: 80px; color: rgba(201,168,76,0.12);
    font-family: 'Georgia', serif; line-height: 1;
  }
  .cio-letter-para {
    font-size: 15.5px; color: var(--text);
    line-height: 1.85; margin-bottom: 22px;
    text-indent: 0;
  }
  .cio-letter-para:first-of-type::first-letter {
    font-size: 42px; font-family: 'Georgia', serif;
    color: var(--gold); float: left; line-height: 0.75;
    margin-right: 8px; margin-top: 8px;
  }
  .cio-letter-sig {
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid rgba(201,168,76,0.2);
  }
  .cio-letter-sig-name {
    font-size: 18px; color: var(--white);
    letter-spacing: 0.04em; margin-bottom: 4px;
  }
  .cio-letter-sig-title {
    font-family: 'Arial', sans-serif; font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold);
  }

  /* ============================================================
     FIVE-LAYER COLLATERAL
  ============================================================ */
  .layer-stack {
    display: flex; flex-direction: column; gap: 0;
    position: relative; padding-left: 0;
  }
  .layer-item {
    position: relative;
    background: var(--navy-card);
    border: 1px solid var(--border-dim);
    border-left: 5px solid var(--gold-dim);
    border-radius: 0 5px 5px 0;
    padding: 22px 28px 22px 22px;
    margin-bottom: 4px;
    transition: all 0.2s ease;
  }
  .layer-item:hover {
    background: rgba(30,45,70,0.9);
    border-left-color: var(--gold);
    transform: translateX(3px);
  }
  .layer-item.layer-1 { border-left-color: #22c55e; }
  .layer-item.layer-2 { border-left-color: #3b82f6; }
  .layer-item.layer-3 { border-left-color: #8b5cf6; }
  .layer-item.layer-4 { border-left-color: var(--gold); }
  .layer-item.layer-5 { border-left-color: #ef4444; background: rgba(30,45,70,0.6); border-color: rgba(201,168,76,0.25); }
  .layer-badge {
    font-family: 'Arial', sans-serif; font-size: 9px;
    letter-spacing: 0.18em; text-transform: uppercase;
    margin-bottom: 7px; font-weight: 700;
  }
  .layer-1 .layer-badge { color: #22c55e; }
  .layer-2 .layer-badge { color: #3b82f6; }
  .layer-3 .layer-badge { color: #8b5cf6; }
  .layer-4 .layer-badge { color: var(--gold); }
  .layer-5 .layer-badge { color: #ef4444; }
  .layer-title { font-size: 17px; color: var(--white); margin-bottom: 10px; }
  .layer-body { font-size: 13.5px; color: var(--text); line-height: 1.7; }
  .layer-connector {
    height: 0; width: 2px;
    background: linear-gradient(to bottom, var(--border), var(--border));
    margin: 0 auto; display: block;
  }

  /* ============================================================
     DEPLOYMENT MODEL
  ============================================================ */
  .deploy-flow {
    display: flex; flex-direction: column; gap: 0;
  }
  .deploy-tier {
    background: var(--navy-card);
    border: 1px solid var(--border-dim);
    border-left: 4px solid var(--gold-dim);
    padding: 18px 24px; margin-bottom: 3px;
    display: flex; align-items: center; gap: 20px;
    border-radius: 0 4px 4px 0;
  }
  .deploy-tier.tier-top {
    border-left-color: var(--gold);
    background: rgba(201,168,76,0.06);
  }
  .deploy-arrow {
    text-align: center; color: var(--gold-dim);
    font-size: 18px; padding: 4px 0;
  }
  .deploy-label {
    font-family: 'Arial', sans-serif; font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--text-muted); margin-bottom: 4px;
  }
  .deploy-value { font-size: 22px; color: var(--gold); font-family: 'Georgia', serif; }
  .deploy-sub { font-family: 'Arial', sans-serif; font-size: 12px; color: var(--silver); margin-top: 2px; }

  /* ============================================================
     INVESTOR MATH TABLE
  ============================================================ */
  .investor-math {
    background: linear-gradient(135deg, rgba(26,40,64,0.9), rgba(8,12,24,0.4));
    border: 2px solid var(--gold);
    border-radius: 6px; overflow: hidden; margin-bottom: 24px;
  }
  .investor-math-header {
    background: rgba(201,168,76,0.12);
    padding: 16px 24px;
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid var(--border);
  }
  .investor-math-title {
    font-family: 'Arial', sans-serif; font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold);
    font-weight: 700;
  }
  .investor-math-body { padding: 24px; }
  .math-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 0; border-bottom: 1px solid var(--border-dim);
  }
  .math-row:last-child { border-bottom: none; }
  .math-row-label { font-family: 'Arial', sans-serif; font-size: 13px; color: var(--silver); }
  .math-row-val { font-size: 18px; color: var(--gold); font-family: 'Georgia', serif; font-weight: bold; }
  .math-row-val.big { font-size: 26px; color: var(--gold-light); }
  .math-row.total { background: rgba(201,168,76,0.07); padding: 16px 14px; margin: 0 -24px; border-radius: 0; }

  /* ============================================================
     PROVIDER GRID
  ============================================================ */
  .provider-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 16px;
  }
  .provider-card {
    background: var(--navy-card); border: 1px solid var(--border-dim);
    border-top: 3px solid var(--gold); padding: 22px 24px; border-radius: 4px;
  }
  .provider-role {
    font-family: 'Arial', sans-serif; font-size: 9px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px;
  }
  .provider-name { font-size: 17px; color: var(--white); margin-bottom: 12px; letter-spacing: 0.02em; }
  .provider-desc { font-family: 'Arial', sans-serif; font-size: 12px; color: var(--text-muted); line-height: 1.65; }

  /* ============================================================
     ORG CHART
  ============================================================ */
  .org-chart {
    display: flex; flex-direction: column; align-items: center; gap: 0; padding: 24px 0;
  }
  .org-node {
    background: var(--navy-card); border: 1px solid var(--border);
    padding: 14px 32px; border-radius: 4px; text-align: center; min-width: 260px;
  }
  .org-node.fund {
    background: linear-gradient(135deg, var(--navy-card), rgba(201,168,76,0.08));
    border-color: var(--gold); border-width: 2px;
  }
  .org-node-title { font-family: 'Arial', sans-serif; font-size: 9.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold-dim); margin-bottom: 4px; }
  .org-node-name { font-size: 14.5px; color: var(--white); letter-spacing: 0.03em; }
  .org-node-sub { font-family: 'Arial', sans-serif; font-size: 11px; color: var(--text-muted); margin-top: 4px; }
  .org-connector {
    width: 2px; height: 26px;
    background: linear-gradient(to bottom, var(--gold-dim), var(--gold-dim));
    position: relative;
  }
  .org-connector::after {
    content: '▼'; position: absolute; bottom: -5px; left: 50%;
    transform: translateX(-50%); color: var(--gold-dim); font-size: 8px;
  }

  /* ============================================================
     PIPELINE BAR
  ============================================================ */
  .pipeline-bar {
    background: var(--navy-light); border-radius: 4px;
    overflow: hidden; height: 44px; margin: 16px 0;
    border: 1px solid var(--border-dim);
  }
  .pipeline-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold-dim) 0%, var(--gold) 60%, var(--gold-light) 100%);
    display: flex; align-items: center; padding: 0 18px;
    font-family: 'Arial', sans-serif; font-size: 13px;
    font-weight: 700; color: var(--navy); width: 100%;
    animation: growBar 1.3s ease-out;
  }
  @keyframes growBar { from { width: 0; } }

  /* ============================================================
     CONTACT
  ============================================================ */
  .contact-card {
    background: var(--navy-card); border: 1px solid var(--border);
    border-top: 4px solid var(--gold); padding: 38px 44px;
    border-radius: 4px; max-width: 560px;
  }
  .contact-name { font-size: 24px; color: var(--white); margin-bottom: 4px; letter-spacing: 0.03em; }
  .contact-title {
    font-family: 'Arial', sans-serif; font-size: 11.5px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 26px; line-height: 1.7;
  }
  .contact-row {
    display: flex; align-items: flex-start; gap: 14px;
    margin-bottom: 16px; font-family: 'Arial', sans-serif;
    font-size: 13px; color: var(--text);
  }
  .contact-icon { color: var(--gold); font-size: 14px; min-width: 20px; text-align: center; margin-top: 1px; }

  /* ============================================================
     SECTION PAGE NOTICE
  ============================================================ */
  .section-page-notice {
    font-family: 'Arial', sans-serif; font-size: 9.5px;
    color: var(--text-muted); text-align: right; margin-top: 52px;
    padding-top: 12px; border-top: 1px solid var(--border-dim);
    letter-spacing: 0.05em;
  }

  /* ============================================================
     MACRO CARD
  ============================================================ */
  .macro-card {
    background: var(--navy-card); border: 1px solid var(--border-dim);
    border-radius: 5px; padding: 24px 28px; position: relative;
    overflow: hidden;
  }
  .macro-card::before {
    content: '';
    position: absolute; top: 0; right: 0;
    width: 140px; height: 140px;
    background: radial-gradient(circle at top right, rgba(201,168,76,0.06), transparent 70%);
    pointer-events: none;
  }
  .macro-card-icon { font-size: 28px; margin-bottom: 12px; }
  .macro-card-title { font-size: 16px; color: var(--gold-light); margin-bottom: 10px; }
  .macro-card-body { font-size: 13.5px; color: var(--text); line-height: 1.7; }

  /* ============================================================
     PRINT
  ============================================================ */
  @media print {
    .sidebar, .header, .disclaimer-bar { display: none !important; }
    .main { margin: 0; padding: 20px 40px; }
    .section { display: block !important; page-break-before: always; }
    .section:first-child { page-break-before: avoid; }
    body { background: white; color: #111; }
    .card, .stat-box, .risk-item { border-color: #ccc; background: #fafafa; }
    .cover-title, h1, h2, h3 { color: #111; }
    a { color: #333; }
  }

  /* ============================================================
     RESPONSIVE
  ============================================================ */
  @media (max-width: 960px) {
    :root { --sidebar-w: 220px; }
    .main { padding: 36px 32px 80px; }
    .cover-title { font-size: 38px; }
    .cio-letter { padding: 30px 32px; }
  }
  @media (max-width: 680px) {
    .sidebar { display: none; }
    :root { --sidebar-w: 0px; }
    .header { padding-left: 20px; }
    .main { padding: 24px 18px 80px; }
    .cio-letter { padding: 22px 20px; }
  }
</style>
</head>
<body>

