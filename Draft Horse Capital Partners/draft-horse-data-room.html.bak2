<!-- ============================================================
     MAIN CONTENT
============================================================ -->
<main class="main">

  <!-- ============================================================
       01 — COVER
  ============================================================ -->
  <section class="section active" id="cover">
    <div class="cover-wrap">
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;">
        <div style="width:52px;height:52px;border:2px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--gold);font-family:'Arial',sans-serif;font-weight:800;letter-spacing:0.05em;flex-shrink:0;background:rgba(201,168,76,0.06);">DH</div>
        <div style="flex:1;height:1px;background:linear-gradient(to right,var(--gold),transparent);"></div>
        <div style="font-family:'Arial',sans-serif;font-size:9px;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold-dim);">Dark Horse Platform · Private Credit Series</div>
      </div>

      <div class="cover-eyebrow">Confidential Investor Data Room — March 2026</div>
      <div class="cover-title">Draft Horse<br>Capital Partners</div>
      <div class="cover-tagline">Single-Mandate Structured Private Credit — Five-Layer Collateral Architecture — Zero Fees</div>

      <div class="cover-meta-row">
        <div class="cover-meta-item">
          <span class="cover-meta-label">Structure</span>
          <span class="cover-meta-val">Reg D 506(c) · §3(c)(1)</span>
