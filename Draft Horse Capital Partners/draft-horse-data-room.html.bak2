        <div class="two-col" style="margin-top:20px;">
          <div style="background:rgba(34,197,94,0.07);border:1px solid rgba(34,197,94,0.2);border-radius:4px;padding:18px 20px;">
            <div style="font-family:'Arial',sans-serif;font-size:9px;letter-spacing:0.16em;text-transform:uppercase;color:var(--green);margin-bottom:8px;font-weight:700;">What Investors Receive</div>
